{
  "family": "esnaaf-backend-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "512",
  "containerDefinitions": [
    {
      "name": "esnaaf-backend",
      "image": "<AWS_ACCOUNT_ID>.dkr.ecr.<AWS_DEFAULT_REGION>.amazonaws.com/esnaaf-backend:latest",
      "portMappings": [
        {
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "NODE_ENV",
          "value": "production"
        },
        {
          "name": "PORT",
          "value": "3000"
        }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:ssm:<AWS_DEFAULT_REGION>:<AWS_ACCOUNT_ID>:parameter/esnaaf/prod/database_url"
        },
        {
          "name": "REDIS_URL",
          "valueFrom": "arn:aws:ssm:<AWS_DEFAULT_REGION>:<AWS_ACCOUNT_ID>:parameter/esnaaf/prod/redis_url"
        },
        {
          "name": "JWT_ACCESS_SECRET",
          "valueFrom": "arn:aws:ssm:<AWS_DEFAULT_REGION>:<AWS_ACCOUNT_ID>:parameter/esnaaf/prod/jwt_access_secret"
        },
        {
          "name": "JWT_REFRESH_SECRET",
          "valueFrom": "arn:aws:ssm:<AWS_DEFAULT_REGION>:<AWS_ACCOUNT_ID>:parameter/esnaaf/prod/jwt_refresh_secret"
        },
        {
          "name": "ENCRYPTION_KEY",
          "valueFrom": "arn:aws:ssm:<AWS_DEFAULT_REGION>:<AWS_ACCOUNT_ID>:parameter/esnaaf/prod/encryption_key"
        },
        {
          "name": "ENCRYPTION_IV",
          "valueFrom": "arn:aws:ssm:<AWS_DEFAULT_REGION>:<AWS_ACCOUNT_ID>:parameter/esnaaf/prod/encryption_iv"
        },
        {
          "name": "WS_SECRET",
          "valueFrom": "arn:aws:ssm:<AWS_DEFAULT_REGION>:<AWS_ACCOUNT_ID>:parameter/esnaaf/prod/ws_secret"
        },
        {
          "name": "GEMINI_API_KEY",
          "valueFrom": "arn:aws:ssm:<AWS_DEFAULT_REGION>:<AWS_ACCOUNT_ID>:parameter/esnaaf/prod/gemini_api_key"
        },
        {
          "name": "NETGSM_USERCODE",
          "valueFrom": "arn:aws:ssm:<AWS_DEFAULT_REGION>:<AWS_ACCOUNT_ID>:parameter/esnaaf/prod/netgsm_usercode"
        },
        {
          "name": "NETGSM_PASSWORD",
          "valueFrom": "arn:aws:ssm:<AWS_DEFAULT_REGION>:<AWS_ACCOUNT_ID>:parameter/esnaaf/prod/netgsm_password"
        },
        {
          "name": "NETGSM_MSGHEADER",
          "valueFrom": "arn:aws:ssm:<AWS_DEFAULT_REGION>:<AWS_ACCOUNT_ID>:parameter/esnaaf/prod/netgsm_msgheader"
        },
        {
          "name": "FCM_PROJECT_ID",
          "valueFrom": "arn:aws:ssm:<AWS_DEFAULT_REGION>:<AWS_ACCOUNT_ID>:parameter/esnaaf/prod/fcm_project_id"
        },
        {
          "name": "FCM_CLIENT_EMAIL",
          "valueFrom": "arn:aws:ssm:<AWS_DEFAULT_REGION>:<AWS_ACCOUNT_ID>:parameter/esnaaf/prod/fcm_client_email"
        },
        {
          "name": "FCM_PRIVATE_KEY",
          "valueFrom": "arn:aws:ssm:<AWS_DEFAULT_REGION>:<AWS_ACCOUNT_ID>:parameter/esnaaf/prod/fcm_private_key"
        },
        {
          "name": "IYZICO_API_KEY",
          "valueFrom": "arn:aws:ssm:<AWS_DEFAULT_REGION>:<AWS_ACCOUNT_ID>:parameter/esnaaf/prod/iyzico_api_key"
        },
        {
          "name": "IYZICO_SECRET_KEY",
          "valueFrom": "arn:aws:ssm:<AWS_DEFAULT_REGION>:<AWS_ACCOUNT_ID>:parameter/esnaaf/prod/iyzico_secret_key"
        },
        {
          "name": "IYZICO_BASE_URL",
          "valueFrom": "arn:aws:ssm:<AWS_DEFAULT_REGION>:<AWS_ACCOUNT_ID>:parameter/esnaaf/prod/iyzico_base_url"
        }
      ],
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "node -e \"const http = require('http'); http.get('http://localhost:3000/api/health', (res) => { process.exit(res.statusCode === 200 ? 0 : 1); }).on('error', () => process.exit(1));\""
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 15
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/esnaaf-backend",
          "awslogs-region": "<AWS_DEFAULT_REGION>",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
