datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

// ── ENUMS (Faz 1) ─────────────────────────────────────────────────────────────

enum UserRole {
  service_seeker
  service_provider
  admin
}

enum RequestStatus {
  pending
  distributed
  completed
  cancelled
}

enum OfferStatus {
  pending
  accepted
  rejected
  cancelled
  archived
}

enum MessageType {
  text
  image
  audio
}

enum AlarmLevel {
  none
  info
  yellow
  red
}

enum DisputeStatus {
  none
  open
  resolved
}

enum JobCompletionStatus {
  pending_provider
  pending_seeker
  completed
  disputed
  cancelled
}

enum StaffRole {
  super_admin
  team_leader
  quality_staff
  ops_staff
  finance_staff
  marketing_staff
  sales_staff
  hr_staff
  executive
  rnd_staff
}

enum AccountStatus {
  pending_approval
  active
  suspended
}

// ── MODELLER (Faz 1 - Aktif) ──────────────────────────────────────────────────

model User {
  id                      String                  @id @default(uuid()) @db.Uuid
  phone                   String                  @unique
  phone_masked            String
  name                    String?
  email                   String?
  role                    UserRole
  esnaaf_id               String?                 @unique
  kvkk_consent            Boolean                 @default(false)
  kvkk_consent_date       DateTime?
  marketing_consent       Boolean                 @default(false)
  is_active               Boolean                 @default(true)
  created_at              DateTime                @default(now())
  deleted_at              DateTime?
  service_provider        ServiceProvider?
  service_requests        ServiceRequest[]
  sent_messages           Message[]               @relation("SentMessages")
  received_messages       Message[]               @relation("ReceivedMessages")
  accepted_offers         AcceptedOffer[]
  fcm_token               String?
  notification_logs       NotificationLog[]
  notification_preference NotificationPreference?
  reviews_written         Review[]                @relation("UserReviews")
  balance                 Decimal                 @default(0) @db.Decimal(10, 2)
  referrals_made          Referral[]              @relation("Referrer")
  referrals_received      Referral[]              @relation("Referee")
  favorites               FavoriteProvider[]      @relation("SeekerFavorites")

  @@map("users")
  @@index([role])
}

model ServiceProvider {
  id                String                 @id @default(uuid()) @db.Uuid
  user_id           String                 @unique @db.Uuid
  user              User                   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  category_ids      String[]               @db.Uuid
  description       String?
  avg_rating        Decimal?               @db.Decimal(3, 2)
  total_jobs        Int                    @default(0)
  response_time_avg Int?
  is_approved       Boolean                @default(false)
  approved_at       DateTime?
  account_status    AccountStatus          @default(pending_approval)
  open_door_right   Boolean                @default(false)
  subscription_id   String?                @db.Uuid
  city              String                 @default("Adana")
  service_districts String[]               @default([])
  offers            Offer[]
  accepted_offers   AcceptedOffer[]
  job_completions   JobCompletion[]
  subscription      Subscription?
  campaign_usages   CampaignUsage[]
  monthly_quotas    ProviderMonthlyQuota[]
  reviews_received  Review[]               @relation("ProviderReviews")
  favorited_by      FavoriteProvider[]     @relation("ProviderFavoritedBy")
  direct_requests   ServiceRequest[]       @relation("DirectProviderRequests")
  saved_cards       SavedCard[]

  @@map("service_providers")
  @@index([city])
  @@index([is_approved])
}

model Category {
  id               String           @id @default(uuid()) @db.Uuid
  name             String           @unique
  isActive         Boolean          @default(true)
  created_at       DateTime         @default(now())
  service_requests ServiceRequest[]

  @@map("categories")
}

model ServiceRequest {
  id                String           @id @default(uuid()) @db.Uuid
  seeker_id         String           @db.Uuid
  seeker            User             @relation(fields: [seeker_id], references: [id], onDelete: Cascade)
  category_id       String           @db.Uuid
  category          Category         @relation(fields: [category_id], references: [id], onDelete: Cascade)
  form_data         Json
  status            RequestStatus    @default(pending)
  created_at        DateTime         @default(now())
  offers            Offer[]
  accepted_offers   AcceptedOffer[]
  messages          Message[]
  job_completions   JobCompletion[]
  phone_reveal_logs PhoneRevealLog[]
  reviews           Review[]

  is_direct           Boolean          @default(false)
  direct_provider_id  String?          @db.Uuid
  created_by_provider Boolean          @default(false)
  direct_price        Decimal?         @db.Decimal(10, 2)
  direct_provider     ServiceProvider? @relation("DirectProviderRequests", fields: [direct_provider_id], references: [id], onDelete: SetNull)
  republished_from_id   String?          @db.Uuid

  @@index([seeker_id, status])
  @@index([status, created_at(sort: Desc)])
  @@index([category_id, status])
  @@index([direct_provider_id])
  @@map("service_requests")
}

model Offer {
  id              String          @id @default(uuid()) @db.Uuid
  job_id          String          @db.Uuid
  job             ServiceRequest  @relation(fields: [job_id], references: [id], onDelete: Cascade)
  provider_id     String          @db.Uuid
  provider        ServiceProvider @relation(fields: [provider_id], references: [id], onDelete: Cascade)
  price           Decimal
  commission_rate Decimal         @default(0) @db.Decimal(5, 2)
  commission_paid Boolean         @default(false)
  message         String?
  status          OfferStatus     @default(pending)
  accepted_at     DateTime?
  created_at      DateTime        @default(now())
  accepted_offers AcceptedOffer[]
  messages        Message[]
  job_completions JobCompletion[]
  appointment_at      DateTime?
  started_at          DateTime?
  cancelled_by        String?
  cancel_reason_code  String?
  cancel_reason_text  String?
  cancelled_at        DateTime?

  @@unique([job_id, provider_id])
  @@index([provider_id, status])
  @@index([job_id, status])
  @@map("offers")
}

model AcceptedOffer {
  id                String          @id @default(uuid()) @db.Uuid
  job_id            String          @db.Uuid
  job               ServiceRequest  @relation(fields: [job_id], references: [id], onDelete: Cascade)
  offer_id          String          @db.Uuid
  offer             Offer           @relation(fields: [offer_id], references: [id], onDelete: Cascade)
  seeker_id         String          @db.Uuid
  seeker            User            @relation(fields: [seeker_id], references: [id], onDelete: Cascade)
  provider_id       String          @db.Uuid
  provider          ServiceProvider @relation(fields: [provider_id], references: [id], onDelete: Cascade)
  accepted_at       DateTime        @default(now())
  seeker_consent    Boolean         @default(false)
  seeker_consent_at DateTime?

  @@index([job_id])
  @@index([provider_id])
  @@map("accepted_offers")
}

model PhoneRevealLog {
  id               String         @id @default(uuid()) @db.Uuid
  requester_id     String         @db.Uuid
  revealed_user_id String         @db.Uuid
  job_id           String         @db.Uuid
  job              ServiceRequest @relation(fields: [job_id], references: [id], onDelete: Cascade)
  revealed_at      DateTime       @default(now())

  @@map("phone_reveal_logs")
  @@index([job_id])
  @@index([requester_id])
}

model TempSession {
  id                   String   @id @default(uuid()) @db.Uuid
  session_uuid         String   @unique
  collected_data       Json?
  chat_step            String?
  converted_to_user_id String?  @db.Uuid
  expires_at           DateTime
  created_at           DateTime @default(now())

  @@map("temp_sessions")
}

model Message {
  id           String         @id @default(uuid()) @db.Uuid
  job_id       String         @db.Uuid
  job          ServiceRequest @relation(fields: [job_id], references: [id], onDelete: Cascade)
  offer_id     String         @db.Uuid
  offer        Offer          @relation(fields: [offer_id], references: [id], onDelete: Cascade)
  sender_id    String         @db.Uuid
  sender       User           @relation("SentMessages", fields: [sender_id], references: [id], onDelete: Cascade)
  receiver_id  String         @db.Uuid
  receiver     User           @relation("ReceivedMessages", fields: [receiver_id], references: [id], onDelete: Cascade)
  content      String
  content_type MessageType    @default(text)
  is_read      Boolean        @default(false)
  created_at   DateTime       @default(now())

  @@index([job_id, created_at(sort: Desc)])
  @@index([receiver_id, is_read])
  @@map("messages")
}

model JobCompletion {
  id                       String              @id @default(uuid()) @db.Uuid
  job_id                   String              @db.Uuid
  job                      ServiceRequest      @relation(fields: [job_id], references: [id], onDelete: Cascade)
  offer_id                 String              @db.Uuid
  offer                    Offer               @relation(fields: [offer_id], references: [id], onDelete: Cascade)
  provider_id              String              @db.Uuid
  provider                 ServiceProvider     @relation(fields: [provider_id], references: [id], onDelete: Cascade)
  seeker_id                String              @db.Uuid
  provider_declared_amount Decimal?
  provider_confirmed       Boolean             @default(false)
  provider_confirmed_at    DateTime?
  seeker_declared_amount   Decimal?
  seeker_confirmed         Boolean             @default(false)
  seeker_confirmed_at      DateTime?
  amount_diff              Decimal?
  amount_diff_pct          Decimal?
  alarm_level              AlarmLevel?
  dispute_status           DisputeStatus       @default(none)
  resolved_by              String?             @db.Uuid
  resolved_at              DateTime?
  resolution_note          String?
  status                   JobCompletionStatus @default(pending_provider)
  created_at               DateTime            @default(now())
  updated_at               DateTime            @updatedAt
  nps_responses            NpsResponse[]

  @@map("job_completions")
  @@index([job_id])
  @@index([provider_id])
  @@index([seeker_id])
  @@index([status])
}

model Staff {
  id            String    @id @default(uuid()) @db.Uuid
  name          String?
  email         String    @unique
  phone         String?
  role          StaffRole
  team_id       String?   @db.Uuid
  is_active     Boolean   @default(true)
  created_by    String?   @db.Uuid
  created_at    DateTime  @default(now())
  last_login_at DateTime?

  @@index([role])
  @@map("staff")
}

// ── FAZ 2+ MODELLERİ (YORUM SATIRI) ───────────────────────────────────────────

model Review {
  id           String       @id @default(uuid()) @db.Uuid
  job_id       String       @db.Uuid
  job          ServiceRequest @relation(fields: [job_id], references: [id], onDelete: Cascade)
  reviewer_id  String       @db.Uuid
  reviewer     User         @relation("UserReviews", fields: [reviewer_id], references: [id], onDelete: Cascade)
  provider_id  String       @db.Uuid
  provider     ServiceProvider @relation("ProviderReviews", fields: [provider_id], references: [id], onDelete: Cascade)
  rating       Int
  comment      String?
  document_url String?
  status       ReviewStatus @default(pending)
  approved_by  String?      @db.Uuid
  approved_at  DateTime?
  created_at   DateTime     @default(now())

  @@map("reviews")
  @@index([provider_id, status])
}

enum ReviewStatus {
  pending
  approved
  rejected
}
