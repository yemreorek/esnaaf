model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  staff_id    String   @db.Uuid
  action      String
  target_type String
  target_id   String?  @db.Uuid
  old_value   Json?
  new_value   Json?
  ip_address  String?
  created_at  DateTime @default(now())

  @@map("audit_logs")
  @@index([staff_id, created_at(sort: Desc)])
}
//
model CallTask {
  id                 String          @id @default(uuid()) @db.Uuid
  assigned_to        String?         @db.Uuid
  job_completion_id  String          @db.Uuid
  customer_id        String          @db.Uuid
  priority           PriorityLevel   @default(normal)
  status             CallTaskStatus  @default(pending)
  attempt_count      Int             @default(0)
  call_result        CallTaskResult?
  notes              String?
  due_at             DateTime
  completed_at       DateTime?
  created_at         DateTime        @default(now())

  @@map("call_tasks")
  @@index([status, priority, created_at])
  @@index([assigned_to])
  @@index([job_completion_id])
  @@index([due_at])
}

enum PriorityLevel {
  normal
  urgent
}

enum CallTaskStatus {
  pending
  in_progress
  done
  escalated
}

enum CallTaskResult {
  satisfied
  partial
  unsatisfied
  unreachable
}
