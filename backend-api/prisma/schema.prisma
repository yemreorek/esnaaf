model NotificationLog {
  id           String             @id @default(uuid()) @db.Uuid
  user_id      String             @db.Uuid
  user         User               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  event_code   String             @db.VarChar(10)
  channel      NotifChannel
  status       NotifStatus        @default(pending)
  message_id   String?
  payload      Json
  sent_at      DateTime           @default(now())
  delivered_at DateTime?

  @@map("notification_logs")
  @@index([user_id, sent_at(sort: Desc)])
}

enum NotifChannel {
  in_app
  sms
  email
  push
}

enum NotifStatus {
  sent
  delivered
  failed
  pending
}

model NotificationPreference {
  id               String   @id @default(uuid()) @db.Uuid
  user_id          String   @unique @db.Uuid
  user             User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  whatsapp_enabled Boolean  @default(true)
  sms_enabled      Boolean  @default(true)
  push_enabled     Boolean  @default(true)
  marketing_email  Boolean  @default(false)
  updated_at       DateTime @updatedAt

  @@map("notification_preferences")
}

model NpsResponse {
  id                String         @id @default(uuid()) @db.Uuid
  job_completion_id String         @db.Uuid
  job_completion    JobCompletion  @relation(fields: [job_completion_id], references: [id], onDelete: Cascade)
  seeker_id         String         @db.Uuid
  provider_id       String         @db.Uuid
  category_id       String         @db.Uuid
  score             Int
  group             NpsGroup
  follow_up_text    String?
  channel           NpsChannel
  responded_at      DateTime
  created_at        DateTime       @default(now())

  @@map("nps_responses")
  @@index([provider_id, created_at(sort: Desc)])
  @@index([seeker_id, created_at(sort: Desc)])
}

enum NpsGroup {
  promoter
  passive
  detractor
}

enum NpsChannel {
  whatsapp
  web
}

model Referral {
  id             String       @id @default(uuid()) @db.Uuid
  referrer_id    String       @db.Uuid
  referrer       User         @relation("Referrer", fields: [referrer_id], references: [id], onDelete: Cascade)
  referee_id     String?      @unique @db.Uuid
  referee        User?        @relation("Referee", fields: [referee_id], references: [id], onDelete: Cascade)
  code           String       @db.VarChar(12)
  type           ReferralType
  reward_amount  Decimal      @db.Decimal(10, 2)
  rewarded       Boolean      @default(false)
  rewarded_at    DateTime?
  created_at     DateTime     @default(now())

  @@map("referrals")
  @@index([referrer_id])
}

enum ReferralType {
  seeker_credit
  provider_discount
}

model FavoriteProvider {
  id          String   @id @default(uuid()) @db.Uuid
  seeker_id   String   @db.Uuid
  provider_id String   @db.Uuid
  approved    Boolean  @default(true)
  created_by  String   @default("seeker")
  created_at  DateTime @default(now()) @db.Timestamp(6)

  // Relations
  seeker   User            @relation("SeekerFavorites", fields: [seeker_id], references: [id], onDelete: Cascade)
  provider ServiceProvider @relation("ProviderFavoritedBy", fields: [provider_id], references: [id], onDelete: Cascade)

  @@unique([seeker_id, provider_id])
  @@index([seeker_id])
  @@index([provider_id])
  @@map("favorite_providers")
}

model SavedCard {
  id               String          @id @default(uuid()) @db.Uuid
  provider_id      String          @db.Uuid
  provider         ServiceProvider @relation(fields: [provider_id], references: [id], onDelete: Cascade)
  card_holder      String
  card_brand       String          // Visa, Mastercard, Troy, vb.
  card_association String?
  card_family      String?
  card_user_key    String          // iyzico cardUserKey
  card_token       String          // iyzico cardToken
  bin_number       String          // İlk 6 hane
  last_four        String          // Son 4 hane
  is_primary       Boolean         @default(true)
  created_at       DateTime        @default(now())
  updated_at       DateTime        @updatedAt

  @@map("saved_cards")
  @@index([provider_id, is_primary])
}
