model Subscription {
  id                      String             @id @default(uuid()) @db.Uuid
  provider_id             String             @unique @db.Uuid
  provider                ServiceProvider    @relation(fields: [provider_id], references: [id], onDelete: Cascade)
  package_type            PackageType
  status                  SubscriptionStatus
  started_at              DateTime
  expires_at              DateTime
  cancelled_at            DateTime?
  iyzico_subscription_ref String?
  admin_granted_by        String?            @db.Uuid
  admin_trial_note        String?
  payments                Payment[]
  campaign_usages         CampaignUsage[]

  @@map("subscriptions")
  @@index([status, expires_at])
}

enum PackageType {
  basic
  standard
  premium
  vip
}

enum SubscriptionStatus {
  trial
  admin_trial
  active
  cancelled
  suspended
  expired
}

model Payment {
  id                     String        @id @default(uuid()) @db.Uuid
  subscription_id        String        @db.Uuid
  subscription           Subscription  @relation(fields: [subscription_id], references: [id], onDelete: Cascade)
  amount                 Decimal
  status                 PaymentStatus
  iyzico_payment_id      String?
  attempt_count          Int
  paid_at                DateTime?
  created_at             DateTime      @default(now())

  @@map("payments")
  @@index([subscription_id, created_at(sort: Desc)])
}

enum PaymentStatus {
  success
  failed
  refunded
}

model Campaign {
  id                  String          @id @default(uuid()) @db.Uuid
  name                String
  code                String          @unique @db.VarChar(50)
  type                CampaignType
  value               Decimal
  upgrade_to          PackageType?
  applicable_packages String[]
  new_users_only      Boolean         @default(false)
  max_uses            Int?
  used_count          Int             @default(0)
  valid_from          DateTime
  valid_until         DateTime
  is_active           Boolean         @default(true)
  created_by          String?         @db.Uuid
  created_at          DateTime        @default(now())
  usages              CampaignUsage[]

  @@map("campaigns")
}

enum CampaignType {
  percent
  fixed
  free_trial
  upgrade
  quota_bonus
}

model CampaignUsage {
  id               String          @id @default(uuid()) @db.Uuid
  campaign_id      String          @db.Uuid
  campaign         Campaign        @relation(fields: [campaign_id], references: [id], onDelete: Cascade)
  provider_id      String          @db.Uuid
  provider         ServiceProvider @relation(fields: [provider_id], references: [id], onDelete: Cascade)
  subscription_id  String          @db.Uuid
  subscription     Subscription    @relation(fields: [subscription_id], references: [id], onDelete: Cascade)
  discount_amount  Decimal
  used_at          DateTime        @default(now())
  created_by_staff String?         @db.Uuid

  @@map("campaign_usage")
  @@index([provider_id])
}

model ProviderMonthlyQuota {
  id             String          @id @default(uuid()) @db.Uuid
  provider_id    String          @db.Uuid
  provider       ServiceProvider @relation(fields: [provider_id], references: [id], onDelete: Cascade)
  month_year     String          @db.VarChar(7)
  accepted_count Int             @default(0)
  monthly_limit  Int?
  reset_at       DateTime
  updated_at     DateTime        @updatedAt

  @@map("provider_monthly_quota")
  @@unique([provider_id, month_year])
}
//
model ResponseTime {
  id                        String   @id @default(uuid()) @db.Uuid
  provider_id               String   @db.Uuid
  job_id                    String   @db.Uuid
  notified_at               DateTime
  responded_at              DateTime?
  response_duration_minutes Int?
  notified_sent             Boolean  @default(false)

  is_rejected               Boolean  @default(false)
  rejection_reason          String?
  rejection_details         String?  @db.Text

  @@map("response_times")
  @@index([provider_id, notified_at(sort: Desc)])
  @@index([notified_sent, notified_at])
}
