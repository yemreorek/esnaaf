# ── Uygulama ──────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=v1
FRONTEND_URL=https://esnaaf.com,https://www.esnaaf.com,https://partner.esnaaf.com
PARTNER_APP_URL=http://localhost:3001
API_URL=http://localhost:3000/api

# ── Veritabanı ────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/esnaaf_db?schema=public

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────
JWT_ACCESS_SECRET=some_super_secret_access_key_min_32_characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=some_super_secret_refresh_key_min_32_characters
JWT_REFRESH_EXPIRES_IN=7d

# ── Telefon Şifreleme ─────────────────────────────────
ENCRYPTION_KEY=some_32_character_encryption_key_
ENCRYPTION_IV=some_16_char_iv_

# ── OTP / SMS (Netgsm) ─────────────────────────────────
NETGSM_USERCODE=
NETGSM_PASSWORD=
NETGSM_MSGHEADER=ESNAAF

# ── OTP ────────────────────────────────────────────────
OTP_EXPIRES_IN_MINUTES=5
OTP_LENGTH=6

# ── Firebase FCM (Push Notification) ─────────────────
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# ── Platform İçi Bildirim (WebSocket) ────────────────
WS_SECRET=some_websocket_secret_token

# ── Google Gemini ─────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash


# ── iyzico ────────────────────────────────────────────
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox.iyzipay.com

# ── AWS S3 / Cloudflare R2 ────────────────────────────
STORAGE_PROVIDER=s3
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=platform-documents
S3_PRESIGNED_URL_EXPIRES=900

# ── Rate Limiting ─────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
THROTTLE_OTP_LIMIT=3

# ── Monitoring ────────────────────────────────────────
SENTRY_DSN=
